# Copy to .env for local development. Never commit real secrets.
APP_ENV=development
HTTP_ADDR=:8080

# Matches docker-compose.yml credentials.
DATABASE_URL=postgres://saydalah:saydalah@localhost:5432/saydalah?sslmode=disable

# Use a long random value in production, e.g. `openssl rand -base64 48`.
JWT_SECRET=dev-only-change-me
JWT_TTL=24h

# Comma-separated browser origins allowed by CORS (future SvelteKit dev server).
CORS_ORIGINS=http://localhost:5173

SHUTDOWN_TIMEOUT=10s
