# Copy to .env for local development. Never commit real secrets.
APP_ENV=development
HTTP_ADDR=:8080

# Matches docker-compose.yml credentials.
DATABASE_URL=postgres://saydalah:saydalah@localhost:5432/saydalah?sslmode=disable

# Use a long random value in production, e.g. `openssl rand -base64 48`.
JWT_SECRET=dev-only-change-me
# Access-token lifetime (short-lived; refresh tokens keep sessions alive).
JWT_TTL=24h
# Refresh-token lifetime.
REFRESH_TTL=720h

# Comma-separated browser origins allowed by CORS (future SvelteKit dev server).
CORS_ORIGINS=http://localhost:5173

SHUTDOWN_TIMEOUT=10s

# Rate limiting (per client IP). Unset = defaults below; a malformed value fails
# startup rather than silently falling back.
RATE_LIMIT_RPS=20
RATE_LIMIT_BURST=40
# Stricter limit applied to POST /auth/login to blunt brute-forcing.
LOGIN_RATE_RPS=0.5
LOGIN_RATE_BURST=5
